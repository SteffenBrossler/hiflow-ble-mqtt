# Environment file for ble-watchdog.sh / ble-watchdog.service.
#
# Copy to /etc/default/ble-watchdog (done automatically by
# install-ble-watchdog.sh) and set COMPOSE_DIR to the directory that
# contains docker-compose.yml and the ./state folder shared with the
# hiflow-ble container. Any path works — it does not need to be inside
# a home directory.

COMPOSE_DIR=/opt/hoymiles-ble-mqtt
