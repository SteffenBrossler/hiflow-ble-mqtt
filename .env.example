# Copy to .env and fill in your values. docker compose reads this file
# automatically (must stay in the same directory as docker-compose.yml).
# .env itself is gitignored — never commit real credentials.

# ── Inverter ──────────────────────────────────────────────
HIFLOW_ADDRESS=RMI-4161A02AE0B9
HIFLOW_ENC_RAND=
HIFLOW_SN=4161A02AE0B9
HIFLOW_BLE_ID=
HIFLOW_PIN=
HIFLOW_INTERVAL=60
HIFLOW_LOGLEVEL=INFO

# ── MQTT ──────────────────────────────────────────────────
MQTT_HOST=192.168.1.10
MQTT_PORT=1883
MQTT_USER=homeassistant
MQTT_PASS=
MQTT_TOPIC=hiflow
